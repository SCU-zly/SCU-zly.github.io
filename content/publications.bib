@inproceedings{zhou2026dear,
  selected={true},
  title = {Mitigating Entity Hallucinations in 3D Radiology Report Generation via Dual-Stream Alignment},
  author = {Lingyu Zhou* and Yue Yu* and Zhang Yi and Xiuyuan Xu},
  year = {2026},
  booktitle = {Proceedings of the AAAI Conference on Artificial Intelligence (AAAI)},
  abstract = {3D radiology report generation often suffers from entity hallucinations where generated reports contain anatomical entities or findings not present in the input volume. We propose DEAR, a dual-stream alignment framework that mitigates entity hallucinations through explicit alignment between visual evidence and textual entities. Our method achieves state-of-the-art performance on multiple benchmarks.},
  description={Proposed DEAR framework to mitigate entity hallucinations in 3D radiology report generation through dual-stream alignment. **AAAI 2026, CCF-A**.},
  keywords={Radiology Report Generation, Entity Hallucination, Medical AI},
  code={https://github.com/SCU-zly/DEAR}
}

@inproceedings{zhou2024ggvmamba,
  selected={true},
  title = {Efficient and Gender-Adaptive Graph Vision Mamba for Pediatric Bone Age Assessment},
  author = {Lingyu Zhou and Zhang Yi and Kai Zhou and Xiuyuan Xu},
  year = {2024},
  booktitle = {Proceedings of the International Conference on Medical Image Computing and Computer-Assisted Intervention (MICCAI)},
  abstract = {Pediatric bone age assessment is a critical clinical task. We propose GGVMamba, an efficient and gender-adaptive framework based on Graph Vision Mamba for automated bone age assessment. By incorporating gender-specific priors into the Mamba architecture with graph-based modeling of skeletal structures, our method achieves superior accuracy with significantly reduced computational cost.},
  description={Proposed GGVMamba, a gender-adaptive Graph Vision Mamba framework for pediatric bone age assessment. **MICCAI 2024, CCF-B**.},
  keywords={Bone Age Assessment, Vision Mamba, Medical Image Analysis},
  code={https://github.com/SCU-zly/GGVMamba}
}

@article{cao2024bayesian,
  title = {A Bayesian Deep Learning Model with Consolidation-to-Tumor Ratio (CTR) Prior Revolutionizes the Prediction of Spread Through Air Spaces (STAS) in Stage IA Lung Adenocarcinoma: A Large-Scale Diagnostic Study},
  author = {Jie Cao* and Nan Chen* and Lingyu Zhou* and others},
  year = {2024},
  journal = {Translational Lung Cancer Research},
  abstract = {Spread through air spaces (STAS) is an important prognostic factor in early-stage lung adenocarcinoma. We develop a Bayesian deep learning model incorporating consolidation-to-tumor ratio (CTR) as a prior for STAS prediction, validated on a large-scale multi-center dataset.},
  description={Developed a Bayesian deep learning model with CTR prior for predicting STAS in lung adenocarcinoma. **Translational Lung Cancer Research, IF=3.5**.},
  keywords={Lung Cancer, STAS, Bayesian Deep Learning, Computer-Aided Diagnosis}
}

@inproceedings{zhou2026nbg,
  selected={true},
  title = {Navigate Before You Generate: Volume Evidence Grounding for 3D Radiology Reports},
  author = {Lingyu Zhou and Dingwen Pi and Zhang Yi and Xiuyuan Xu},
  year = {2026},
  booktitle = {Proceedings of the International Conference on Machine Learning (ICML)},
  abstract = {We propose a novel paradigm for 3D radiology report generation that first navigates through the volumetric data to ground evidence before generating textual reports. This evidence-grounding approach ensures that every generated sentence is supported by specific volumetric regions, significantly improving report faithfulness and clinical reliability.},
  description={Proposed a volume evidence grounding paradigm for 3D radiology report generation. **ICML 2026, CCF-A, Under Review**.},
  keywords={Radiology Report Generation, Evidence Grounding, Medical AI}
}

@inproceedings{zhou2026forematch,
  selected={true},
  title = {ForeMatch: Rethinking Foreground Consistency for Efficient Semi-Supervised 3D Medical Image Segmentation},
  author = {Lingyu Zhou and Zhengyang Xu and Zhang Yi and Deng Xiong and Xiuyuan Xu},
  year = {2026},
  booktitle = {Proceedings of the ACM International Conference on Multimedia (ACM MM)},
  abstract = {Semi-supervised 3D medical image segmentation faces challenges in leveraging unlabeled data effectively. We propose ForeMatch, which rethinks foreground consistency to improve pseudo-label quality and training efficiency. Our method achieves state-of-the-art performance with fewer labeled samples.},
  description={Proposed ForeMatch for efficient semi-supervised 3D medical image segmentation via foreground consistency. **ACM MM 2026, CCF-A, Under Review**.},
  keywords={Semi-Supervised Learning, Medical Image Segmentation, 3D Segmentation},
  code={https://github.com/SCU-zly/ForeMatch}
}

@article{cui2025invasiveness,
  title = {Predicting the Invasiveness of Pulmonary Ground Glass Opacities Using Self-Supervised Learning: A Prospective Multicenter Diagnostic Study},
  author = {Ruichen Cui* and Xiuyuan Xu* and Nan Chen* and Lingyu Zhou* and others},
  year = {2025},
  journal = {Thorax},
  abstract = {Ground glass opacities (GGOs) are common findings in lung CT scans, and predicting their invasiveness is crucial for clinical management. We develop a self-supervised learning framework for GGO invasiveness prediction, validated in a prospective multicenter diagnostic study.},
  description={Self-supervised learning framework for predicting GGO invasiveness in a prospective multicenter study. **Thorax, Under Review, IF=8.3**.},
  keywords={Ground Glass Opacity, Self-Supervised Learning, Lung Cancer, Computer-Aided Diagnosis}
}

@article{liang2024tuberculosis,
  title = {Deep Learning for Precise Diagnosis and Subtype Triage of Drug-Resistant Tuberculosis on Chest Computed Tomography},
  author = {Shufan Liang and Xiuyuan Xu and Zhe Yang and Qiuyu Du and Lingyu Zhou and others},
  year = {2024},
  journal = {MedComm},
  abstract = {Drug-resistant tuberculosis remains a major global health challenge. We develop a deep learning framework for precise diagnosis and subtype triage of drug-resistant TB from chest CT images, achieving high accuracy in multi-center validation.},
  description={Deep learning framework for drug-resistant tuberculosis diagnosis and subtype triage from chest CT. **MedComm, IF=10.7**.},
  keywords={Tuberculosis, Drug Resistance, Deep Learning, CT Diagnosis}
}

@inproceedings{zhou2021ltsnet,
  title = {LTS-NET: Lung Tissue Segmentation from CT Images using Fully Convolutional Neural Network},
  author = {Lingyu Zhou and Xiuyuan Xu and Kai Zhou and Jixiang Guo},
  year = {2021},
  booktitle = {2021 11th International Conference on Information Science and Technology (ICIST)},
  abstract = {Accurate lung tissue segmentation from CT images is a fundamental step in computer-aided diagnosis. We propose LTS-NET, a fully convolutional neural network for automated lung tissue segmentation, achieving competitive performance on benchmark datasets.},
  description={Proposed LTS-NET for automated lung tissue segmentation from CT images using FCN.},
  keywords={Lung Segmentation, CT Images, Fully Convolutional Network}
}
